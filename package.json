{
  "name": "poisonsniffer",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "package:extension": "node ./scripts/package-extension.mjs",
    "test": "node --test apps/*/test/*.test.js packages/*/test/*.test.js scripts/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
