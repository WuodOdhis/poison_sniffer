{
  "name": "poisonsniffer",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "poisonsniffer",
      "workspaces": [
        "packages/*",
        "apps/*"
      ],
      "devDependencies": {
        "typescript": "^5.6.3"
      }
    },
    "apps/sentinel-api": {
      "name": "@sentinel/api",
      "version": "0.1.0"
    },
    "node_modules/@sentinel/adapter": {
      "resolved": "packages/sentinel-adapter",
      "link": true
    },
    "node_modules/@sentinel/api": {
      "resolved": "apps/sentinel-api",
      "link": true
    },
    "node_modules/@sentinel/core": {
      "resolved": "packages/sentinel-core",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/sentinel-adapter": {
      "name": "@sentinel/adapter",
      "version": "0.1.0"
    },
    "packages/sentinel-core": {
      "name": "@sentinel/core",
      "version": "0.1.0"
    }
  }
}
